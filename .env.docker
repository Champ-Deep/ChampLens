# ─────────────────────────────────────────────────
# ChampLens — Docker environment variables
# Copy this file and fill in real values before running:
#   cp .env.docker .env.docker.local
#   docker compose --env-file .env.docker.local up -d
# ─────────────────────────────────────────────────

# MongoDB credentials (used by both docker-compose and backend)
MONGO_INITDB_ROOT_USERNAME=champlens
MONGO_INITDB_ROOT_PASSWORD=change_this_mongo_password

# Redis password
REDIS_PASSWORD=change_this_redis_password

# Clerk — sign up at https://clerk.com, create an app, copy the keys from API Keys.
# The publishable key (pk_test_... / pk_live_...) is safe to ship to the browser.
# The secret key (sk_test_... / sk_live_...) MUST stay server-side.
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Same publishable key — Vite bakes it into the SPA bundle at build time.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Public URLs — update to your actual domain in production
FRONTEND_URL=http://localhost
FILE_BASE_URL=http://localhost/files

# QR logo path inside the container
LOGO_PATH=/app/src/assets/qr-logo.jpeg

# Admin role is set via Clerk publicMetadata.role = "admin" in the Clerk dashboard.

# Optional: Resend (for password reset emails)
RESEND_API_KEY=

# Optional: OpenRouter (for AI features — Phase 2)
OPENROUTER_API_KEY=
