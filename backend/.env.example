PORT=3001
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/champlens

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

FRONTEND_URL=http://localhost:5173

# File storage base URL (used to build public URLs for GridFS files)
FILE_BASE_URL=http://localhost:3001/files

# Champions Group logo path (absolute or relative to src/).
# Default in code is ./assets/qr-logo.jpeg — override here if you ship a custom logo.
LOGO_PATH=./assets/qr-logo.jpeg

# Optional: Resend for password reset emails
RESEND_API_KEY=

# Optional: OpenRouter for AI (Phase 2)
OPENROUTER_API_KEY=
