PORT=3001
NODE_ENV=development

# Local dev: use docker-compose's mongo container. Production: Railway injects this
# from the Mongo service via ${{Mongo.MONGO_URL}} — see SETUP.md "Railway Deployment".
MONGODB_URI=mongodb://champlens:champlens_secret@localhost:27017/champlens?authSource=admin

# Clerk — get these from https://dashboard.clerk.com → API Keys.
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

REDIS_URL=redis://localhost:6379

FRONTEND_URL=http://localhost:5173

# File storage base URL (used to build public URLs for GridFS files)
FILE_BASE_URL=http://localhost:3001/files

# Champions Group logo path (absolute or relative to src/).
# Default in code is ./assets/qr-logo.jpeg — override here if you ship a custom logo.
LOGO_PATH=./assets/qr-logo.jpeg

# Optional: Resend for password reset emails
RESEND_API_KEY=

# Optional: OpenRouter for AI (Phase 2)
OPENROUTER_API_KEY=
